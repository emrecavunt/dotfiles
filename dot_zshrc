# ============================================================================
# SELF-DOCUMENTING HELP SYSTEM
# ============================================================================
# Usage: Add #@ category: description before any alias or function
# Run `cheat` to see all categories, `cheat k8s` to filter

cheat() {
  local filter="${1:-}"
  local zshrc="${ZDOTDIR:-$HOME}/.zshrc"

  echo ""
  echo "🚀 PLATFORM ENGINEER CHEAT SHEET"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  [[ -n "$filter" ]] && echo "  Filtering by: $filter"

  awk -v filter="$filter" '
    /^#@ / {
      line = $0
      sub(/^#@ /, "", line)
      idx = index(line, ": ")
      if (idx > 0) {
        category = substr(line, 1, idx - 1)
        desc = substr(line, idx + 2)
      } else {
        category = line
        desc = ""
      }
      next_is_cmd = 1
      next
    }
    next_is_cmd && /^alias [a-zA-Z0-9_-]+="/ {
      if (filter == "" || tolower(category) ~ tolower(filter)) {
        line = $0
        sub(/^alias /, "", line)
        idx = index(line, "=")
        if (idx > 0) {
          cmd = substr(line, 1, idx - 1)
          if (!(category in cats)) {
            cats[category] = ""
            cat_order[++cat_count] = category
          }
          cats[category] = cats[category] sprintf("  %-18s %s\n", cmd, desc)
        }
      }
      next_is_cmd = 0
    }
    next_is_cmd && /^[a-zA-Z0-9_-]+\(\)/ {
      if (filter == "" || tolower(category) ~ tolower(filter)) {
        cmd = $0
        sub(/\(\).*/, "", cmd)
        if (!(category in cats)) {
          cats[category] = ""
          cat_order[++cat_count] = category
        }
        cats[category] = cats[category] sprintf("  %-18s %s\n", cmd, desc)
      }
      next_is_cmd = 0
    }
    !/^#@ / && !/^alias / && !/^[a-zA-Z0-9_-]+\(\)/ { next_is_cmd = 0 }
    END {
      split("k8s k8s-debug tf tg gcp aws az docker git net util nav history fzf ai", order_arr)
      split("☸️ :🔧:🏗️ :🌍:☁️ :🔶:🔷:🐳:📝:🌐:⚙️ :📁:📜:🔍:🤖", icon_arr, ":")
      for (i = 1; i <= 15; i++) {
        cat = order_arr[i]
        if (cat in cats) {
          printf "\n  %s %s\n", icon_arr[i], toupper(cat)
          printf "  ────────────────────────────────────────\n"
          printf "%s", cats[cat]
          delete cats[cat]
        }
      }
      for (cat in cats) {
        printf "\n  📌 %s\n", toupper(cat)
        printf "  ────────────────────────────────────────\n"
        printf "%s", cats[cat]
      }
    }
  ' "$zshrc"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  💡 Usage: cheat [filter]  Examples: cheat k8s, cheat aws, cheat git"
  echo ""
}

