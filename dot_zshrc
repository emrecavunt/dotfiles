ctx() {
  echo ""
  echo "  ☸️  K8s Context:   $(kubectl config current-context 2>/dev/null || echo 'none')"
  echo "  ☸️  K8s Namespace: $(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null || echo 'default')"
