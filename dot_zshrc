#@ net: SSL expiry for host
sslexpiry() {
  local host=$1
  if [[ -z "$host" ]]; then
    echo "Usage: sslexpiry <host[:port]>"
    return 1
  fi
  [[ "$host" != *":"* ]] && host="$host:443"
  openssl s_client -servername "${host%%:*}" -connect "$host" 2>/dev/null \
    | openssl x509 -noout -dates
}

