#@ fzf: fuzzy find files with preview
alias ff="fzf --preview 'bat --color=always {}'"

#@ fzf: fuzzy k8s context switch
kctx() {
  kubectl config use-context $(kubectl config get-contexts -o name | fzf --prompt="context> ")
}

#@ fzf: fuzzy namespace switch
kns-fzf() {
  kubectl config set-context --current \
    --namespace=$(kubectl get ns -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' \
    | fzf --prompt="namespace> ")
}

#@ fzf: fuzzy git branch checkout
gbf() {
  git checkout $(git branch -a | fzf --prompt="branch> " \
    | sed 's/remotes\/origin\///' | xargs)
}

#@ fzf: fuzzy git log viewer
glf() {
  git log --oneline | fzf --prompt="commit> " --preview 'git show --color=always {1}'
}

#@ fzf: fuzzy gcloud config switch
gcpf() {
  gcloud config configurations activate \
    $(gcloud config configurations list --format="value(name)" | fzf --prompt="gcp config> ")
}

#@ fzf: fuzzy AWS profile switch
awsf() {
  export AWS_PROFILE=$(aws configure list-profiles | fzf --prompt="aws profile> ")
  echo "AWS_PROFILE set to: $AWS_PROFILE"
}

#@ fzf: fuzzy kubectl context with preview
kctx-preview() {
  kubectl config get-contexts \
    | fzf --header-lines=1 --prompt="context> " \
      --preview 'kubectl config get-contexts {2} 2>/dev/null' \
    | awk '{print $2}' \
    | xargs kubectl config use-context
}

