  kubectl run testbox-host-$(date +%s) --rm -i --tty \
    --image=nicolaka/netshoot \
    --restart=Never \
    --overrides='{
      "spec": {
        "hostNetwork": true,
        "containers": [{
          "name": "testbox",
          "image": "nicolaka/netshoot",
          "stdin": true,
          "tty": true
