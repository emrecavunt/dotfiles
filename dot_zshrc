#@ util: check all tool versions
versions() {
  echo ""
  echo "  📊 TOOL VERSIONS"
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  check_ver() {
    local cmd=$1 name=$2 flag=${3:---version}
    if command -v "$cmd" &>/dev/null; then
      ver=$($cmd ${=flag} 2>&1 | head -n 1)
      printf "  %-16s %s\n" "$name" "$ver"
    else
      printf "  %-16s %s\n" "$name" "not installed"
    fi
  }
  check_ver "go"          "Go"           "version"
  check_ver "node"        "Node"         "--version"
  check_ver "python3"     "Python"       "--version"
  check_ver "terraform"   "Terraform"    "--version"
  check_ver "terragrunt"  "Terragrunt"   "--version"
  check_ver "kubectl"     "kubectl"      "version --client --short"
  check_ver "helm"        "Helm"         "version --short"
  check_ver "k9s"         "k9s"          "version --short"
  check_ver "gcloud"      "gcloud"       "version"
  check_ver "aws"         "AWS CLI"      "--version"
  check_ver "az"          "Azure CLI"    "--version"
  check_ver "docker"      "Docker"       "--version"
  check_ver "claude"      "Claude Code"  "--version"
  check_ver "mise"        "mise"         "--version"
  echo ""
}

#@ util: decode k8s secret (all keys or specific key)
kdecode() {
  local secret=$1 key=$2
  if [[ -z "$secret" ]]; then
    echo "Usage: kdecode <secret-name> [key]"
    return 1
  fi
  if [[ -z "$key" ]]; then
    kubectl get secret "$secret" -o json \
      | jq -r '.data | to_entries[] | "\(.key): \(.value | @base64d)"'
  else
    kubectl get secret "$secret" -o jsonpath="{.data.$key}" | base64 -d
    echo
  fi
}

